<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    android:id="@+id/index_recycler"
    android:background="@drawable/shape">

    <ImageView
        android:id="@+id/my_publish_photo"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        android:layout_gravity="center_horizontal"
        android:src="@mipmap/cat" />

    <TextView
        android:layout_margin="5dp"
        android:id="@+id/my_publish_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textColor="@color/black"
        android:textSize="15sp"/>

    <TextView
        android:id="@+id/my_publish_money"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:maxLength="20"
        android:textColor="@color/myred"
        android:textSize="17sp" />

    <!-- 添加一个水平布局来放置状态标签和删除按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="5dp"
        android:paddingHorizontal="5dp"
        android:layout_marginBottom="5dp">

        <!-- 状态标签 -->
        <TextView
            android:id="@+id/my_publish_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/status_background" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 删除按钮 -->
        <Button
            android:id="@+id/delete_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="删除"
            android:backgroundTint="#FF3B30"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />

    </LinearLayout>

</LinearLayout>